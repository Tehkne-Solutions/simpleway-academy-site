---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LeadForm from '../components/LeadForm.astro';
import MethodTimeline from '../components/MethodTimeline.astro';
import PlanGrid from '../components/PlanGrid.astro';
import CycleWidget from '../components/CycleWidget.astro';
import Accordion from '../components/Accordion.astro';
import Icon from '../components/Icon.astro';
import { faqs, site, unsplash } from '../data/site';
import { courseSchema, faqSchema } from '../utils/schema';
---
<BaseLayout
  title="SimpleWay Academy | Inglês leve, prático e guiado por tecnologia"
  description="SimpleWay Academy é uma escola de inglês com método próprio, app oficial, speaking, histórias guiadas, Desafio das 72 Frases e revisão inteligente."
  schema={[courseSchema(), faqSchema()]}
>
  <Header />
  <main id="conteudo">
    <section class="hero-v2">
      <div class="container hero-grid-v2">
        <div class="hero-copy-v2">
          <p class="eyebrow">SimpleWay English + App oficial</p>
          <h1>Inglês com leveza, prática real e um caminho claro para falar.</h1>
          <p class="lead">A SimpleWay Academy une escola de alto nível, método neurodidático e app interativo para transformar aula, apostila e prática em uma jornada simples, divertida e mensurável.</p>
          <div class="hero-actions-v2">
            <a class="btn btn-primary" href="/pre-matricula/">Entrar na lista de interesse</a>
            <a class="btn btn-outline" href="/metodologia/">Conhecer o método</a>
          </div>
          <div class="hero-pills-v2" aria-label="Diferenciais da SimpleWay">
            <span><strong>APF</strong> Fala Inicial</span>
            <span><strong>72</strong> frases gamificadas</span>
            <span><strong>4</strong> habilidades treinadas</span>
          </div>
        </div>

        <div class="hero-scene-v2" aria-label="Experiência SimpleWay Academy">
          <div class="image-frame main-photo floaty">
            <img src={unsplash.hero} alt="Alunos estudando juntos em ambiente moderno" width="1200" height="900" loading="eager" fetchpriority="high" />
            <div class="image-badge">O site apresenta. O app ensina. O aluno pratica.</div>
          </div>
          <div class="method-badge badge-blue">
            <Icon name="spark" />
            <span><strong>Fala Inicial</strong><small>perguntas sobre a vida real</small></span>
          </div>
          <div class="method-badge badge-red">
            <Icon name="bolt" />
            <span><strong>Desafio 72</strong><small>jogo de fluência ativa</small></span>
          </div>
          <div class="app-card-v2">
            <div class="app-card-top"><span></span><span></span><span></span></div>
            <p>Lesson Journey</p>
            <strong>Ouvir → falar → praticar → revisar</strong>
            <div class="app-meter"><i></i></div>
          </div>
        </div>
      </div>
    </section>

    <section class="section stats-row-section">
      <div class="container stats-row">
        <article><strong>5</strong><span>etapas por lição</span></article>
        <article><strong>7</strong><span>lições por ciclo</span></article>
        <article><strong>72</strong><span>frases no desafio</span></article>
        <article><strong>App</strong><span>aluno + professor</span></article>
      </div>
    </section>

    <section class="section gold-soft">
      <div class="container grid-2">
        <div>
          <p class="eyebrow">Por que existe</p>
          <h2>O inglês não precisa parecer uma parede. Ele precisa virar caminho.</h2>
          <p class="lead">Muitos alunos travam porque estudam partes soltas: gramática de um lado, vocabulário de outro e pouca fala real. A SimpleWay organiza a experiência em uma sequência que o cérebro entende: primeiro sentido, depois resposta, prática, revisão e domínio.</p>
          <div class="pain-grid">
            <article><span>01</span><strong>Menos trava</strong><p>O aluno começa com perguntas guiadas e respostas possíveis, sem pular direto para uma cobrança pesada.</p></article>
            <article><span>02</span><strong>Mais contexto</strong><p>Histórias bilíngues criam sentido antes da regra, reduzindo a tradução mental e a sensação de decorar.</p></article>
            <article><span>03</span><strong>Mais constância</strong><p>Gamificação, revisão e progresso visual ajudam o aluno a enxergar evolução e continuar.</p></article>
          </div>
        </div>
        <div class="image-frame split-photo">
          <img src={unsplash.study} alt="Aluno estudando com notebook e caderno em ambiente claro" loading="lazy" width="1200" height="900" />
        </div>
      </div>
    </section>

    <section class="section method-section-v2">
      <div class="container">
        <div class="section-head-wide">
          <div>
            <p class="eyebrow">Método SimpleWay</p>
            <h2>Uma aula organizada como jornada: entender, responder, praticar, revisar e evoluir.</h2>
          </div>
          <p class="lead">O método não fica escondido em documentação técnica. No site ele aparece de forma clara; no app ele vira interação, áudio, fala, cards, pontos, feedback e checkpoint.</p>
        </div>
        <MethodTimeline />
      </div>
    </section>

    <section class="section blue-soft app-section-v2">
      <div class="container grid-2">
        <div class="app-phone-v2 card">
          <div class="phone-header">
            <img src={site.logos.mark} alt="" width="42" height="45" />
            <span>SimpleWay App</span>
          </div>
          <div class="lesson-card-mini">
            <small>Lesson 1</small>
            <strong>My Name is Michael McNew</strong>
            <div class="progress"><span></span></div>
          </div>
          <div class="skill-list">
            <span>🎧 Listening</span>
            <span>🎙️ Speaking</span>
            <span>✍️ Writing</span>
            <span>📖 Reading</span>
          </div>
        </div>
        <div>
          <p class="eyebrow">Plataforma oficial</p>
          <h2>O app é onde o curso acontece de verdade.</h2>
          <p class="lead">O site é a vitrine inteligente da escola. O app SimpleWay Academy é a plataforma de aprendizagem: lições interativas, speaking, XP, revisão, progresso, professor/admin e trilhas por ciclo.</p>
          <div class="feature-grid-v2">
            <article><Icon name="phone" /><strong>App do aluno</strong><span>Atividades interativas e prática entre aulas.</span></article>
            <article><Icon name="chart" /><strong>Progresso visível</strong><span>Domínio por habilidade e revisão.</span></article>
            <article><Icon name="school" /><strong>Professor</strong><span>Conteúdo, turmas e qualidade pedagógica.</span></article>
            <article><Icon name="target" /><strong>Checkpoint</strong><span>Validação antes de avançar.</span></article>
          </div>
        </div>
      </div>
    </section>

    <section class="section cycle-section-v2">
      <div class="container">
        <p class="eyebrow">Ciclo 1</p>
        <h2>6 lições progressivas + 1 checkpoint para consolidar fluência.</h2>
        <p class="lead">O primeiro ciclo começa com identidade e presente, passa por passado, rotina, família, futuro e sentimentos. A sétima lição não introduz conteúdo novo: ela revisa, mistura e valida domínio.</p>
        <CycleWidget />
      </div>
    </section>

    <section class="section image-band-v2">
      <div class="container band-grid-v2">
        <div class="image-frame"><img src={unsplash.teacher} alt="Professora orientando aluno em sala moderna" loading="lazy" width="900" height="700" /></div>
        <div class="band-copy card">
          <p class="eyebrow">Experiência premium</p>
          <h2>Conteúdo profundo, mas apresentado em partes fáceis de consumir.</h2>
          <p>A SimpleWay evita despejar textos enormes no aluno. O conteúdo aparece em cards, timelines, acordeões, desafios e blocos visuais para melhorar leitura, atenção e ação.</p>
        </div>
        <div class="image-frame"><img src={unsplash.online} alt="Aluno estudando online com notebook" loading="lazy" width="900" height="700" /></div>
      </div>
    </section>

    <section class="section plans-section-v2">
      <div class="container">
        <div class="section-head-wide">
          <div>
            <p class="eyebrow">Planos</p>
            <h2>Três formas de começar com a SimpleWay.</h2>
          </div>
          <p class="lead">A oferta pode começar com turma ao vivo, plataforma ou aulas gravadas com comunidade. A estrutura foi pensada para crescer sem perder clareza.</p>
        </div>
        <PlanGrid />
      </div>
    </section>

    <section class="section form-section-v2">
      <div class="container grid-2">
        <div>
          <p class="eyebrow">Pré-matrícula</p>
          <h2>Quer montar uma turma, testar o app ou receber os próximos planos?</h2>
          <p class="lead">O formulário abre uma mensagem pronta no WhatsApp {site.whatsappDisplay}. Assim o atendimento já recebe objetivo, nível e melhor caminho para começar.</p>
        </div>
        <LeadForm title="Quero entrar na lista SimpleWay" />
      </div>
    </section>

    <section class="section faq-section-v2 soft">
      <div class="container grid-2">
        <div>
          <p class="eyebrow">Dúvidas frequentes</p>
          <h2>Respostas rápidas para decidir com segurança.</h2>
          <p class="lead">O FAQ organiza objeções reais sobre curso, app, método, speaking, revisão e turmas.</p>
        </div>
        <Accordion items={faqs} />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
<style>
  .hero-v2{position:relative;overflow:hidden;padding:clamp(58px,8vw,96px) 0 48px;background:linear-gradient(135deg,#FFFDF7 0%,#F4F9FF 52%,#FFF3CC 100%)}
  .hero-v2::before{content:"";position:absolute;inset:-10% -5% auto auto;width:520px;height:520px;border-radius:999px;background:rgba(230,57,70,.12);filter:blur(2px)}
  .hero-v2::after{content:"";position:absolute;left:-180px;bottom:-220px;width:620px;height:620px;border-radius:999px;background:rgba(0,87,216,.12)}
  .hero-grid-v2{display:grid;grid-template-columns:.92fr 1.08fr;gap:clamp(30px,5vw,70px);align-items:center;position:relative;z-index:1}
  .hero-copy-v2 .lead{margin-top:22px}.hero-actions-v2{display:flex;gap:14px;flex-wrap:wrap;margin:28px 0 22px}.hero-pills-v2{display:flex;flex-wrap:wrap;gap:10px}.hero-pills-v2 span{background:white;border:1px solid var(--sw-line);border-radius:999px;padding:10px 14px;box-shadow:0 10px 25px rgba(16,32,51,.06);font-weight:850;color:var(--sw-muted)}.hero-pills-v2 strong{color:var(--sw-blue)}
  .hero-scene-v2{position:relative}.main-photo img{min-height:520px}.method-badge{position:absolute;z-index:3;display:flex;align-items:center;gap:10px;background:white;border:1px solid var(--sw-line);box-shadow:var(--shadow-soft);padding:12px 14px;border-radius:24px;min-width:232px}.method-badge svg{width:28px;height:28px}.method-badge strong{display:block}.method-badge small{display:block;color:var(--sw-muted);font-weight:850}.badge-blue{left:-20px;top:36px;color:var(--sw-blue)}.badge-red{right:-16px;bottom:72px;color:var(--sw-red)}.app-card-v2{position:absolute;left:44px;bottom:-24px;z-index:3;width:min(330px,70%);background:linear-gradient(135deg,#0057D8,#2E7BEF);color:white;border-radius:26px;padding:18px;box-shadow:0 30px 60px rgba(0,87,216,.25)}.app-card-top{display:flex;gap:6px;margin-bottom:12px}.app-card-top span{width:9px;height:9px;border-radius:999px;background:rgba(255,255,255,.8)}.app-card-v2 p{margin:0 0 4px;color:rgba(255,255,255,.78);font-weight:850}.app-card-v2 strong{font-family:Poppins,Inter,sans-serif}.app-meter{height:10px;background:rgba(255,255,255,.25);border-radius:999px;margin-top:14px;overflow:hidden}.app-meter i{display:block;width:74%;height:100%;background:var(--sw-gold);border-radius:inherit}
  .stats-row-section{padding:30px 0;background:white}.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}.stats-row article{border:1px solid var(--sw-line);border-radius:24px;background:linear-gradient(180deg,#fff,#F8FBFF);padding:18px;text-align:center;box-shadow:0 10px 28px rgba(16,32,51,.05)}.stats-row strong{font-family:Poppins,Inter,sans-serif;font-size:clamp(1.8rem,3vw,2.6rem);color:var(--sw-blue);display:block;line-height:1}.stats-row article:nth-child(2) strong{color:var(--sw-red)}.stats-row article:nth-child(3) strong{color:#D49A00}.stats-row span{font-weight:850;color:var(--sw-muted)}
  .pain-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:24px}.pain-grid article{background:white;border:1px solid var(--sw-line);border-radius:24px;padding:20px;box-shadow:0 12px 32px rgba(16,32,51,.06)}.pain-grid span{display:inline-grid;place-items:center;width:40px;height:40px;border-radius:14px;background:var(--sw-gold);font-weight:900;margin-bottom:14px}.pain-grid article:nth-child(2) span{background:var(--sw-blue);color:white}.pain-grid article:nth-child(3) span{background:var(--sw-red);color:white}.pain-grid p{color:var(--sw-muted);font-size:.95rem;margin-bottom:0}
  .section-head-wide{display:grid;grid-template-columns:1.05fr .95fr;gap:28px;align-items:end;margin-bottom:34px}.section-head-wide .lead{margin:0}.method-section-v2{background:white}.feature-grid-v2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:26px}.feature-grid-v2 article{display:grid;gap:8px;background:white;border:1px solid var(--sw-line);border-radius:24px;padding:18px;box-shadow:0 12px 30px rgba(16,32,51,.06)}.feature-grid-v2 svg{color:var(--sw-blue)}.feature-grid-v2 span{color:var(--sw-muted);font-weight:750}.app-phone-v2{max-width:430px;margin-inline:auto;background:linear-gradient(180deg,#FFFFFF,#ECF5FF);border:10px solid #102033;border-radius:42px;box-shadow:0 36px 80px rgba(16,32,51,.18)}.phone-header{display:flex;align-items:center;gap:10px;font-weight:900}.phone-header img{width:38px;height:auto}.lesson-card-mini{margin:22px 0;padding:18px;border-radius:26px;background:white;box-shadow:0 14px 32px rgba(16,32,51,.08)}.lesson-card-mini small{color:var(--sw-red);font-weight:900;text-transform:uppercase;letter-spacing:.12em}.lesson-card-mini strong{display:block;font-family:Poppins,Inter,sans-serif;font-size:1.35rem;margin:8px 0 16px}.progress{height:12px;background:#E7EEF7;border-radius:999px;overflow:hidden}.progress span{display:block;width:76%;height:100%;background:linear-gradient(90deg,var(--sw-blue),var(--sw-gold));border-radius:inherit}.skill-list{display:grid;grid-template-columns:1fr 1fr;gap:10px}.skill-list span{padding:12px;border-radius:16px;background:white;border:1px solid var(--sw-line);font-weight:850;text-align:center}.cycle-section-v2{background:linear-gradient(180deg,#FFFFFF,#FFF7DF)}.band-grid-v2{display:grid;grid-template-columns:1fr 1.05fr 1fr;gap:18px;align-items:stretch}.band-grid-v2 .image-frame img{min-height:420px}.band-copy{display:flex;flex-direction:column;justify-content:center;background:linear-gradient(180deg,#fff,#F1F7FF)}.band-copy h2{font-size:clamp(1.8rem,3.2vw,3.15rem)}.band-copy p:not(.eyebrow){color:var(--sw-muted)}.plans-section-v2{background:white}.form-section-v2{background:linear-gradient(135deg,rgba(0,87,216,.1),rgba(255,209,102,.18),rgba(230,57,70,.08))}
  @media(max-width:1050px){.hero-grid-v2{grid-template-columns:1fr}.hero-copy-v2{text-align:left}.main-photo img{min-height:390px}.section-head-wide,.band-grid-v2{grid-template-columns:1fr}.band-grid-v2 .image-frame img{min-height:280px}}
  @media(max-width:760px){.stats-row,.pain-grid,.feature-grid-v2{grid-template-columns:1fr}.method-badge,.app-card-v2{position:static;margin-top:12px;width:100%;min-width:0}.hero-scene-v2{display:grid;gap:12px}.hero-pills-v2 span{width:100%;text-align:center}.main-photo img{min-height:300px}.skill-list{grid-template-columns:1fr}.split-photo{order:-1}}
</style>
