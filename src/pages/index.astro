---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LeadForm from '../components/LeadForm.astro';
import MethodTimeline from '../components/MethodTimeline.astro';
import PlanGrid from '../components/PlanGrid.astro';
import CycleWidget from '../components/CycleWidget.astro';
import Accordion from '../components/Accordion.astro';
import Icon from '../components/Icon.astro';
import { faqs, site, unsplash } from '../data/site';
import { courseSchema, faqSchema } from '../utils/schema';
---
<BaseLayout
  title="SimpleWay Academy | Escola de inglês com app, método e prática real"
  description="Conheça a SimpleWay Academy: inglês com Fala Inicial, histórias guiadas, Desafio das 72 Frases, app oficial, speaking e revisão inteligente."
  schema={[courseSchema(), faqSchema()]}
>
  <Header />
  <main id="conteudo">
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">SimpleWay English + App oficial</p>
          <h1>Inglês leve, divertido e guiado para você finalmente falar.</h1>
          <p class="lead">Uma escola de cursos com cara de produto digital premium: metodologia própria, aulas com propósito, prática ativa e um app que transforma cada lição em jornada.</p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="/pre-matricula/">Entrar na lista de interesse</a>
            <a class="btn btn-gold" href={`https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent('Olá! Quero conhecer a SimpleWay Academy.')}`}>Chamar no WhatsApp</a>
          </div>
          <div class="pill-row hero-pills" aria-label="Diferenciais SimpleWay">
            <span class="pill"><strong>APF</strong> Fala Inicial</span>
            <span class="pill"><strong>72</strong> frases por lição</span>
            <span class="pill"><strong>4</strong> habilidades</span>
          </div>
        </div>
        <div class="hero-visual">
          <div class="image-frame hero-image floaty">
            <img src={unsplash.hero} alt="Estudantes felizes em uma escola moderna" width="1200" height="900" loading="eager" fetchpriority="high" />
            <div class="image-badge">O site apresenta. O app ensina. O aluno pratica.</div>
          </div>
          <div class="mini-widget widget-one">
            <span class="icon-bubble gold"><Icon name="spark" /></span>
            <strong>Fala Inicial</strong>
            <small>Comece falando sobre você</small>
          </div>
          <div class="mini-widget widget-two">
            <span class="icon-bubble red"><Icon name="bolt" /></span>
            <strong>Activation 72</strong>
            <small>Treino gamificado</small>
          </div>
        </div>
      </div>
    </section>

    <section class="section trust-band">
      <div class="container trust-grid">
        <article><strong>5 etapas</strong><span>por lição</span></article>
        <article><strong>7 lições</strong><span>por ciclo</span></article>
        <article><strong>72 frases</strong><span>no desafio principal</span></article>
        <article><strong>App oficial</strong><span>para aluno e professor</span></article>
      </div>
    </section>

    <section class="section problem-section">
      <div class="container grid-2">
        <div class="image-frame">
          <img src={unsplash.study} alt="Aluno estudando inglês com caderno e tecnologia" width="1200" height="900" loading="lazy" />
        </div>
        <div>
          <p class="eyebrow">O problema que resolvemos</p>
          <h2>Não é falta de vontade. É falta de caminho claro.</h2>
          <p class="lead">Muita gente passa anos vendo regra, lista de palavra e aula solta, mas trava quando precisa responder uma pergunta simples. A SimpleWay organiza o aprendizado em pequenos ciclos: entender, falar, treinar, revisar e desbloquear.</p>
          <div class="problem-list">
            <span>❌ Curso que vira só gramática</span>
            <span>❌ Prática oral insuficiente</span>
            <span>❌ Falta de revisão inteligente</span>
            <span>✅ Método visual, guiado e mensurável</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section method-section">
      <div class="container">
        <div class="method-head">
          <div>
            <p class="eyebrow">Método SimpleWay</p>
            <h2>O aluno entende o porquê de cada etapa.</h2>
          </div>
          <p class="lead">A metodologia não fica escondida em apostila ou README. Ela aparece como experiência de produto: cards, checkpoints, speaking, histórias, desafios e feedback.</p>
        </div>
        <MethodTimeline />
      </div>
    </section>

    <section class="section app-section">
      <div class="container grid-2">
        <div>
          <p class="eyebrow">Plataforma oficial</p>
          <h2>O app SimpleWay Academy é onde o curso ganha vida.</h2>
          <p class="lead">O site vende e educa. O app ensina, acompanha e registra progresso. Nele, o aluno treina escuta, fala, escrita e leitura em uma experiência gamificada com XP, revisão e trilhas por ciclo.</p>
          <div class="feature-grid">
            <article><Icon name="phone" /><strong>App do aluno</strong><span>Lições, speaking, XP e revisão.</span></article>
            <article><Icon name="chart" /><strong>Progresso</strong><span>Domínio por habilidade.</span></article>
            <article><Icon name="school" /><strong>Professor</strong><span>Qualidade pedagógica e auditoria.</span></article>
            <article><Icon name="target" /><strong>Checkpoint</strong><span>Validação antes de avançar.</span></article>
          </div>
        </div>
        <div class="app-mock card">
          <div class="app-top"><span></span><span></span><span></span></div>
          <div class="app-content">
            <p class="eyebrow">Lesson 1</p>
            <h3>My Name is Michael McNew</h3>
            <div class="progress"><span style="width:74%"></span></div>
            <div class="app-steps">
              <strong>Fala Inicial</strong>
              <strong>História Guiada</strong>
              <strong>Desafio das 72</strong>
              <strong>Revisão Inteligente</strong>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section cycle-section">
      <div class="container">
        <p class="eyebrow">Ciclo 1</p>
        <h2>Uma jornada de 6 lições progressivas + 1 checkpoint.</h2>
        <p class="lead">O primeiro ciclo começa com identidade e presente, passa por passado, rotina, família, futuro e sentimentos. A sétima lição não adiciona conteúdo novo: ela revisa, mistura e valida domínio.</p>
        <CycleWidget />
      </div>
    </section>

    <section class="section plans-section">
      <div class="container">
        <div class="method-head">
          <div>
            <p class="eyebrow">Planos</p>
            <h2>Escolha o formato ideal para começar.</h2>
          </div>
          <p class="lead">A oferta pode ser aula ao vivo com app, uso da plataforma ou aulas gravadas com comunidade. O objetivo é começar simples e evoluir com estrutura.</p>
        </div>
        <PlanGrid />
      </div>
    </section>

    <section class="section image-strip" aria-label="Ambiente SimpleWay">
      <div class="container strip-grid">
        <img src={unsplash.teacher} alt="Professor em sala de aula moderna" loading="lazy" width="900" height="700" />
        <img src={unsplash.classroom} alt="Crianças em ambiente educacional colorido" loading="lazy" width="900" height="700" />
        <img src={unsplash.online} alt="Estudo online em notebook" loading="lazy" width="900" height="700" />
      </div>
    </section>

    <section class="section form-section">
      <div class="container grid-2">
        <div>
          <p class="eyebrow">Próximo passo</p>
          <h2>Quer montar uma turma ou testar a plataforma?</h2>
          <p class="lead">Envie seu interesse pelo formulário. Ele abre uma mensagem pronta no WhatsApp {site.whatsappDisplay}, com as informações que ajudam a direcionar o atendimento.</p>
        </div>
        <LeadForm />
      </div>
    </section>

    <section class="section faq-section">
      <div class="container grid-2">
        <div>
          <p class="eyebrow">FAQ</p>
          <h2>Respostas rápidas para decidir com segurança.</h2>
          <p class="lead">O FAQ também ajuda o SEO, porque responde dúvidas reais sobre metodologia, plataforma, speaking e formato de curso.</p>
        </div>
        <Accordion items={faqs} />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
<style>
  .hero{padding:clamp(54px,8vw,92px) 0 44px;position:relative;overflow:hidden}.hero::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 15% 20%,rgba(255,209,102,.5),transparent 22rem),radial-gradient(circle at 85% 12%,rgba(0,87,216,.14),transparent 24rem),radial-gradient(circle at 70% 90%,rgba(230,57,70,.12),transparent 22rem);pointer-events:none}.hero-grid{display:grid;grid-template-columns:1.02fr .98fr;gap:clamp(28px,5vw,64px);align-items:center;position:relative}.hero-copy{position:relative;z-index:2}.hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin:26px 0 20px}.hero-pills{margin-top:6px}.hero-visual{position:relative}.hero-image img{min-height:470px}.mini-widget{position:absolute;background:white;border:1px solid var(--sw-line);border-radius:22px;box-shadow:var(--shadow-soft);padding:12px 14px;display:grid;grid-template-columns:48px 1fr;gap:10px;align-items:center;min-width:210px}.mini-widget strong{display:block}.mini-widget small{color:var(--sw-muted);font-weight:800}.widget-one{left:-24px;top:38px}.widget-two{right:-8px;bottom:54px}.trust-band{padding:28px 0}.trust-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}.trust-grid article{background:white;border:1px solid var(--sw-line);border-radius:22px;padding:18px;text-align:center;box-shadow:0 10px 30px rgba(16,32,51,.06)}.trust-grid strong{display:block;font-family:Poppins,Inter,sans-serif;font-size:1.45rem;color:var(--sw-blue)}.trust-grid span{color:var(--sw-muted);font-weight:800}.problem-section{background:linear-gradient(180deg,#fffdf7,#f2f7ff)}.problem-list{display:grid;gap:10px;margin-top:22px}.problem-list span{background:white;border:1px solid var(--sw-line);border-radius:16px;padding:12px 14px;font-weight:900;box-shadow:0 10px 26px rgba(16,32,51,.05)}.method-head{display:grid;grid-template-columns:1fr 1fr;gap:28px;align-items:end;margin-bottom:28px}.app-section{background:linear-gradient(135deg,#eaf3ff,#fff5d3)}.feature-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:24px}.feature-grid article{background:white;border:1px solid var(--sw-line);border-radius:20px;padding:18px;box-shadow:0 10px 26px rgba(16,32,51,.06)}.feature-grid svg{color:var(--sw-blue);margin-bottom:10px}.feature-grid strong{display:block}.feature-grid span{color:var(--sw-muted);font-size:.92rem}.app-mock{background:#102033;color:white;border:0;min-height:440px;display:flex;flex-direction:column}.app-top{display:flex;gap:8px}.app-top span{width:12px;height:12px;border-radius:999px;background:var(--sw-gold)}.app-top span:nth-child(2){background:var(--sw-red)}.app-top span:nth-child(3){background:var(--sw-blue)}.app-content{margin:auto 0}.app-content h3{color:white;font-size:2rem}.app-content .eyebrow{color:var(--sw-gold)}.progress{height:14px;border-radius:999px;background:rgba(255,255,255,.14);overflow:hidden;margin:24px 0}.progress span{display:block;height:100%;border-radius:inherit;background:linear-gradient(90deg,var(--sw-gold),var(--sw-red),var(--sw-blue))}.app-steps{display:grid;gap:10px}.app-steps strong{padding:14px 16px;border-radius:16px;background:rgba(255,255,255,.1)}.cycle-section{background:#fff}.plans-section{background:linear-gradient(180deg,#fffdf7,#f7fbff)}.strip-grid{display:grid;grid-template-columns:1.2fr .8fr 1fr;gap:16px}.strip-grid img{width:100%;height:280px;object-fit:cover;border-radius:28px;box-shadow:var(--shadow-soft);border:6px solid white}.strip-grid img:nth-child(2){margin-top:36px}.form-section{background:linear-gradient(135deg,#fff6da,#eff6ff)}
  @media(max-width:980px){.hero-grid,.method-head{grid-template-columns:1fr}.hero-image img{min-height:320px}.widget-one,.widget-two{position:static;margin-top:12px}.hero-visual{display:grid;gap:12px}.trust-grid{grid-template-columns:1fr 1fr}.strip-grid{grid-template-columns:1fr}.strip-grid img{height:250px}.strip-grid img:nth-child(2){margin-top:0}.feature-grid{grid-template-columns:1fr}}
  @media(max-width:560px){.hero{padding-top:42px}.hero-actions{display:grid}.trust-grid{grid-template-columns:1fr}.hero-image img{min-height:250px}.app-mock{min-height:360px}.app-content h3{font-size:1.5rem}}
</style>
