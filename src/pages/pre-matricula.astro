---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LeadForm from '../components/LeadForm.astro';
---
<BaseLayout title="Pré-matrícula SimpleWay Academy | Lista de interesse">
  <Header />
  <main class="section">
    <div class="narrow">
      <p class="eyebrow">Lista de interesse</p>
      <h1>Entre na pré-matrícula da SimpleWay Academy.</h1>
      <p class="lead">Preencha seus dados para receber informações sobre turmas, plataforma, planos e próximos testes do app.</p>
      <div class="card"><LeadForm /></div>
    </div>
  </main>
  <Footer />
</BaseLayout>
<style>h1{font-size:clamp(2.5rem,6vw,4.4rem)}.card{margin-top:28px}</style>
