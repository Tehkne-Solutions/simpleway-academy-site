---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LeadForm from '../components/LeadForm.astro';
import { unsplash } from '../data/site';
---
<BaseLayout title="Pré-matrícula | SimpleWay Academy" description="Entre na lista de interesse da SimpleWay Academy e receba orientação pelo WhatsApp sobre turmas, app e planos.">
  <Header />
  <main id="conteudo"><section class="section page-hero"><div class="container grid-2"><div><p class="eyebrow">Pré-matrícula</p><h1>Entre na lista de interesse SimpleWay.</h1><p class="lead">Conte seu objetivo e receba orientação sobre o melhor formato: turma ao vivo, plataforma, gravadas ou parceria para escola/empresa.</p></div><div class="image-frame"><img src={unsplash.online} alt="Pessoa estudando online" width="1200" height="900" loading="eager" /></div></div></section><section class="section form-section"><div class="container"><LeadForm title="Enviar pré-matrícula pelo WhatsApp" /></div></section></main><Footer />
</BaseLayout>
<style>.page-hero{background:linear-gradient(135deg,#fff6d8,#eaf3ff)}.form-section{background:#fff}</style>
