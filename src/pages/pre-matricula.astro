---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LeadForm from '../components/LeadForm.astro';
---
<BaseLayout title="Pré-matrícula | SimpleWay Academy" description="Entre na lista de interesse da SimpleWay Academy e receba informações sobre turmas, plataforma e planos.">
  <Header />
  <main id="conteudo"><section class="section page-hero"><div class="container grid-2 top-align"><div class="page-head"><p class="eyebrow">Pré-matrícula</p><h1>Entre na lista de interesse.</h1><p class="lead">Preencha os dados para iniciar uma conversa com a SimpleWay Academy. O envio abre uma mensagem pronta no WhatsApp.</p></div><div class="card"><LeadForm /></div></div></section></main><Footer />
</BaseLayout>

<style>
.page-hero{padding-top:clamp(58px,8vw,96px)}.page-head{max-width:900px}.actions{display:flex;flex-wrap:wrap;gap:14px;margin-top:28px}.gap-top{margin-top:28px}.article-card{display:grid;gap:10px}.article-card span{color:#ffd166;font-weight:900;text-transform:uppercase;letter-spacing:.12em;font-size:.78rem}.legal h2{margin-top:34px}.legal p,.legal li{color:#c8d0dc;line-height:1.8}@media(max-width:720px){.actions{display:grid}}
</style>
