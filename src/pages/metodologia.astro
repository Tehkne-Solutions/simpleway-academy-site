---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { breadcrumbSchema, faqSchema } from '../utils/schema';
import { homeFaqs, lessonSteps, methodPillars, site } from '../data/site';
---
<BaseLayout title="Metodologia SimpleWay | Imersão, fala ativa e Activation 72" description="Conheça o Método SimpleWay: Imersão Guiada, Treino Neural de Frases, Ciclo de Fala Ativa, Activation 72 e Review." schema={[breadcrumbSchema([{name:'Início',url:site.url},{name:'Metodologia',url:`${site.url}/metodologia`}]), faqSchema(homeFaqs)]}>
  <Header />
  <main id="conteudo">
    <section class="section page-hero">
      <div class="container grid-2">
        <div class="page-head">
          <p class="eyebrow">Metodologia</p>
          <h1>O Caminho SimpleWay</h1>
          <p class="lead">Uma metodologia pensada para transformar o estudo em uma jornada clara: o aluno entende, responde, pratica, revisa e evolui.</p>
          <div class="actions"><a class="btn btn-primary" href="/pre-matricula">Entrar na lista</a><a class="btn btn-outline" href="/simpleway-english">Ver o curso</a></div>
        </div>
        <aside class="card hero-panel"><strong>5 steps</strong><p>OPI, Mini-story, Q&A, Activation 72 e Review em uma sequência simples para aprender com propósito.</p></aside>
      </div>
    </section>
    <section class="section">
      <div class="container cards-3">
        {methodPillars.map((pillar) => <article class="card step-card"><span>pilar</span><h2>{pillar.title}</h2><p>{pillar.detail}</p></article>)}
      </div>
    </section>
    <section class="section cta-band">
      <div class="container">
        <div class="page-head center"><p class="eyebrow">Fluxo da lição</p><h2>Do primeiro contato à revisão inteligente.</h2></div>
        <div class="cards-2 gap-top">
          {lessonSteps.map((step, index) => <article class="card step-card"><span>Step {index + 1}</span><h3>{step.title}</h3><p>{step.description}</p></article>)}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-hero { padding-top: clamp(58px, 8vw, 96px); }
  .page-head { max-width: 900px; }
  .page-head .lead { max-width: 820px; }
  .gap-top { margin-top: 28px; }
  .step-card { display: grid; gap: 12px; }
  .step-card span { color: #ffd166; font-weight: 900; text-transform: uppercase; letter-spacing: .12em; font-size: .78rem; }
  .list { display: grid; gap: 12px; padding: 0; margin: 0; list-style: none; }
  .list li { padding: 14px 16px; border-radius: 16px; background: rgba(0,87,216,.12); border: 1px solid rgba(234,234,234,.1); color: #d8e0eb; font-weight: 800; }
  .hero-panel { min-height: 360px; display: grid; align-content: center; }
  .hero-panel strong { color: #ffd166; font-size: 3rem; font-family: Poppins, Inter, sans-serif; line-height: 1; }
  .cta-band { background: linear-gradient(90deg, rgba(0,87,216,.22), rgba(255,209,102,.09)); border-block: 1px solid rgba(234,234,234,.08); }
  .actions { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 28px; }
  @media(max-width:720px){ .actions{display:grid}.hero-panel{min-height:auto}.hero-panel strong{font-size:2.3rem} }
</style>
