---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const testimonials = [
  { name: 'Aluno em validação', text: 'A proposta da SimpleWay me ajudou a entender o caminho da aula e perceber que falar precisa ser praticado desde o começo.' },
  { name: 'Responsável por turma piloto', text: 'A combinação de aula, app e revisão cria uma experiência mais clara para acompanhar evolução.' },
  { name: 'Professor parceiro', text: 'O método facilita a criação de lições completas: fala, história, perguntas, prática e revisão.' }
];
---
<BaseLayout title="Depoimentos | SimpleWay Academy" description="Veja percepções de alunos, responsáveis e professores sobre a experiência SimpleWay Academy.">
  <Header />
  <main id="conteudo"><section class="section page-hero"><div class="container"><p class="eyebrow">Prova social</p><h1>Depoimentos e percepções da experiência SimpleWay.</h1><p class="lead">Esta página está preparada para receber depoimentos reais conforme as primeiras turmas e pilotos forem validados.</p></div></section><section class="section"><div class="container grid-3">{testimonials.map((item) => <article class="card testimonial"><p>“{item.text}”</p><strong>{item.name}</strong></article>)}</div></section></main><Footer />
</BaseLayout>
<style>.page-hero{background:linear-gradient(135deg,#fff6d8,#eaf3ff)}.testimonial p{font-size:1.08rem;color:var(--sw-muted)}.testimonial strong{color:var(--sw-blue)}</style>
