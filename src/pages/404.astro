---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Página não encontrada | SimpleWay Academy">
  <Header />
  <main class="section">
    <div class="narrow card">
      <p class="eyebrow">404</p>
      <h1>Página não encontrada.</h1>
      <p>O caminho que você tentou acessar não existe ou foi movido.</p>
      <a class="btn btn-primary" href="/">Voltar para a home</a>
    </div>
  </main>
  <Footer />
</BaseLayout>
<style>.card{text-align:center}h1{font-size:clamp(2.4rem,6vw,4.5rem)}.btn{margin-top:20px}</style>
