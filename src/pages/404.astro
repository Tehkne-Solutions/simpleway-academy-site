---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Página não encontrada | SimpleWay Academy" description="A página não foi encontrada.">
  <Header />
  <main id="conteudo"><section class="section"><div class="container notfound"><p class="eyebrow">404</p><h1>Ops, essa página saiu da rota.</h1><p class="lead">Volte para a home e continue explorando a SimpleWay Academy.</p><a class="btn btn-primary" href="/">Voltar para a home</a></div></section></main><Footer />
</BaseLayout>
<style>.notfound{text-align:center}.notfound h1,.notfound .lead{margin-inline:auto}.notfound .btn{margin-top:18px}</style>
