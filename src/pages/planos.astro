---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LeadForm from '../components/LeadForm.astro';
import PlanGrid from '../components/PlanGrid.astro';
import Accordion from '../components/Accordion.astro';
const planFaq = [
  { question: 'Os valores já estão fechados?', answer: 'Os planos podem variar conforme turma, carga horária, acesso ao app e formato. O site capta interesse e direciona a proposta ideal pelo WhatsApp.' },
  { question: 'Posso começar só pela plataforma?', answer: 'Sim. A plataforma SimpleWay pode ser usada como caminho inicial para estudar no próprio ritmo, com possibilidade de evoluir para turma ao vivo.' },
  { question: 'Tem opção para duas pessoas ou pequenos grupos?', answer: 'Sim. A SimpleWay pode montar formatos para duplas, pequenos grupos, turmas fechadas e projetos especiais.' }
];
---
<BaseLayout title="Planos SimpleWay Academy | Turmas, plataforma e gravadas" description="Conheça os formatos da SimpleWay Academy: turma ao vivo com app, plataforma separada, aulas gravadas com comunidade e planos para escolas.">
  <Header />
  <main id="conteudo">
    <section class="section page-hero"><div class="container"><p class="eyebrow">Planos</p><h1>Comece simples e evolua com estrutura.</h1><p class="lead">A SimpleWay foi pensada para vender sem complicar: captação clara, conversa pelo WhatsApp e plano ajustado ao perfil do aluno, turma ou instituição.</p></div></section>
    <section class="section"><div class="container"><PlanGrid /></div></section>
    <section class="section compare"><div class="container grid-2"><div><p class="eyebrow">Como escolher</p><h2>O plano certo depende da rotina de prática.</h2><p class="lead">Quem precisa de compromisso e feedback humano tende a evoluir melhor com turma ao vivo. Quem já tem disciplina pode começar pela plataforma. Quem precisa de flexibilidade pode usar aulas gravadas com comunidade.</p></div><Accordion items={planFaq} /></div></section>
    <section class="section"><div class="container grid-2"><div><p class="eyebrow">Receber orientação</p><h2>Envie seu objetivo e montamos o melhor caminho.</h2></div><LeadForm title="Quero entender os planos" /></div></section>
  </main>
  <Footer />
</BaseLayout>
<style>.page-hero{background:linear-gradient(135deg,#fff6d8,#eaf3ff)}.compare{background:#f7fbff}</style>
