---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Accordion from '../components/Accordion.astro';
import { faqs } from '../data/site';
import { faqSchema } from '../utils/schema';
---
<BaseLayout title="FAQ | SimpleWay Academy" description="Perguntas frequentes sobre SimpleWay Academy, app, método, Fala Inicial, Desafio das 72 Frases e planos." schema={[faqSchema()]}> <Header /><main id="conteudo"><section class="section page-hero"><div class="container"><p class="eyebrow">FAQ</p><h1>Perguntas frequentes</h1><p class="lead">Respostas diretas para entender como o site, o app e a metodologia SimpleWay se conectam.</p></div></section><section class="section"><div class="container"><Accordion items={faqs} /></div></section></main><Footer /></BaseLayout>
<style>.page-hero{background:linear-gradient(135deg,#eaf3ff,#fff6d8)}</style>
