---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Termos de Uso | SimpleWay Academy">
  <Header />
  <main class="section">
    <div class="narrow">
      <p class="eyebrow">Termos</p>
      <h1>Termos de Uso</h1>
      <p>Estes termos serão refinados antes da publicação comercial. O site institucional apresenta informações, conteúdos e formulários de interesse da SimpleWay Academy.</p>
      <p>A plataforma oficial de ensino é o app SimpleWay Academy.</p>
    </div>
  </main>
  <Footer />
</BaseLayout>
