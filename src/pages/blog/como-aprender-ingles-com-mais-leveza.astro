---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { articleSchema } from '../../utils/schema';
const post = { title: 'Como aprender inglês com mais leveza', description: 'Um guia para estudar inglês com método, contexto, fala ativa e rotina sustentável.', slug: 'como-aprender-ingles-com-mais-leveza' };
---
<BaseLayout title="Como aprender inglês com mais leveza | SimpleWay Academy" description="Um guia para estudar inglês com método, contexto, fala ativa e rotina sustentável." schema={articleSchema(post)}>
  <Header />
  <main id="conteudo"><article class="section page-hero"><div class="narrow article"><p class="eyebrow">Aprendizado</p><h1>Como aprender inglês com mais leveza</h1><p class="lead">Um guia para estudar inglês com método, contexto, fala ativa e rotina sustentável.</p><h2>Aprender leve não é aprender pouco</h2><p>Leveza significa reduzir ruído, ansiedade e excesso de teoria solta. O aluno precisa de contexto, repetição inteligente e pequenas vitórias visíveis.</p><h2>O caminho prático</h2><ul><li>Ouça e entenda uma situação real.</li><li>Responda perguntas simples sobre você.</li><li>Pratique frases úteis até ganhar velocidade.</li><li>Revise antes de avançar.</li></ul><div class="callout"><strong>SimpleWay:</strong> o site apresenta o caminho; o app conduz a prática.</div></div></article></main><Footer />
</BaseLayout>
<style>.article h2{margin-top:42px}.article p,.article li{color:#c8d0dc;line-height:1.85}.article ul{padding-left:22px}.article .callout{margin:32px 0;padding:24px;border-radius:24px;border:1px solid rgba(255,209,102,.28);background:rgba(255,209,102,.08)}

.page-hero{padding-top:clamp(58px,8vw,96px)}.page-head{max-width:900px}.actions{display:flex;flex-wrap:wrap;gap:14px;margin-top:28px}.gap-top{margin-top:28px}.article-card{display:grid;gap:10px}.article-card span{color:#ffd166;font-weight:900;text-transform:uppercase;letter-spacing:.12em;font-size:.78rem}.legal h2{margin-top:34px}.legal p,.legal li{color:#c8d0dc;line-height:1.8}@media(max-width:720px){.actions{display:grid}}

</style>
