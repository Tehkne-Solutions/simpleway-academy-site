---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
const posts = [
  { href: '/blog/como-aprender-ingles-com-mais-leveza/', title: 'Como aprender inglês com mais leveza', tag: 'Aprendizagem' },
  { href: '/blog/metodo-simpleway/', title: 'O que é o Método SimpleWay', tag: 'Metodologia' },
  { href: '/blog/activation-72/', title: 'Por que o Desafio das 72 Frases funciona', tag: 'Prática' },
  { href: '/blog/como-destravar-a-fala-em-ingles/', title: 'Como destravar a fala em inglês', tag: 'Speaking' },
  { href: '/blog/por-que-historias-ajudam-na-fluencia/', title: 'Por que histórias ajudam na fluência', tag: 'Imersão' }
];
---
<BaseLayout title="Blog SimpleWay Academy | Inglês, speaking e metodologia" description="Artigos da SimpleWay Academy sobre aprendizado de inglês, fala, histórias, repetição inteligente e metodologia.">
  <Header />
  <main id="conteudo"><section class="section page-hero"><div class="container"><p class="eyebrow">Blog e SEO</p><h1>Conteúdo para aprender melhor antes mesmo de entrar no app.</h1><p class="lead">Artigos estratégicos para explicar a metodologia, educar interessados e fortalecer a autoridade da SimpleWay nos mecanismos de busca.</p></div></section><section class="section"><div class="container post-grid">{posts.map((post) => <a class="post-card card" href={post.href}><span>{post.tag}</span><h2>{post.title}</h2><p>Ler artigo completo</p></a>)}</div></section></main><Footer />
</BaseLayout>
<style>.page-hero{background:linear-gradient(135deg,#fff6d8,#eaf3ff)}.post-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:20px}.post-card{text-decoration:none}.post-card span{display:inline-flex;background:var(--sw-gold);border-radius:999px;padding:7px 10px;font-weight:900;margin-bottom:14px}.post-card h2{font-size:1.45rem}.post-card p{color:var(--sw-blue);font-weight:900}@media(max-width:900px){.post-grid{grid-template-columns:1fr}}</style>
