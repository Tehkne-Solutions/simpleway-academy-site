---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { articleSchema } from '../../utils/schema';
const post = { title: 'Como destravar a fala em inglês', description: 'O caminho para sair da compreensão passiva e começar a responder com confiança.', slug: 'como-destravar-a-fala-em-ingles' };
---
<BaseLayout title="Como destravar a fala em inglês | SimpleWay Academy" description="O caminho para sair da compreensão passiva e começar a responder com confiança." schema={articleSchema(post)}>
  <Header />
  <main id="conteudo"><article class="section page-hero"><div class="narrow article"><p class="eyebrow">Speaking</p><h1>Como destravar a fala em inglês</h1><p class="lead">O caminho para sair da compreensão passiva e começar a responder com confiança.</p><h2>O problema da fala</h2><p>Muitos alunos entendem mais do que conseguem falar. Isso acontece porque compreensão passiva e resposta ativa são habilidades diferentes.</p><h2>A solução</h2><p>Começar com perguntas pessoais, respostas guiadas e prática frequente reduz o medo de errar e aumenta a velocidade de reação.</p></div></article></main><Footer />
</BaseLayout>
<style>.article h2{margin-top:42px}.article p,.article li{color:#c8d0dc;line-height:1.85}.article ul{padding-left:22px}.article .callout{margin:32px 0;padding:24px;border-radius:24px;border:1px solid rgba(255,209,102,.28);background:rgba(255,209,102,.08)}

.page-hero{padding-top:clamp(58px,8vw,96px)}.page-head{max-width:900px}.actions{display:flex;flex-wrap:wrap;gap:14px;margin-top:28px}.gap-top{margin-top:28px}.article-card{display:grid;gap:10px}.article-card span{color:#ffd166;font-weight:900;text-transform:uppercase;letter-spacing:.12em;font-size:.78rem}.legal h2{margin-top:34px}.legal p,.legal li{color:#c8d0dc;line-height:1.8}@media(max-width:720px){.actions{display:grid}}

</style>
