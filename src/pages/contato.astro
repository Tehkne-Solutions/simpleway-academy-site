---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LeadForm from '../components/LeadForm.astro';
import { site } from '../data/site';
---
<BaseLayout title="Contato | SimpleWay Academy" description="Fale com a SimpleWay Academy pelo WhatsApp e conheça os formatos de curso, app e parceria educacional.">
  <Header />
  <main id="conteudo"><section class="section page-hero"><div class="container grid-2"><div><p class="eyebrow">Contato</p><h1>Fale com a SimpleWay Academy.</h1><p class="lead">Atendimento via WhatsApp {site.whatsappDisplay}. Use o formulário para enviar uma mensagem estruturada e acelerar a conversa.</p><a class="btn btn-gold" href={`https://wa.me/${site.whatsappNumber}`}>Abrir WhatsApp</a></div><LeadForm compact={true} title="Mensagem rápida" /></div></section></main><Footer />
</BaseLayout>
<style>.page-hero{background:linear-gradient(135deg,#eaf3ff,#fff6d8)}</style>
