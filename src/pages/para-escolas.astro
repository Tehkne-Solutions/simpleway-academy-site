---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="SimpleWay para escolas e empresas" description="SimpleWay Academy para escolas, empresas e parceiros que querem uma solução de ensino com app, método e acompanhamento.">
  <Header />
  <main id="conteudo">
    <section class="section page-hero">
      <div class="container grid-2">
        <div class="page-head"><p class="eyebrow">B2B e parcerias</p><h1>Uma solução educacional pronta para escolas, empresas e turmas fechadas.</h1><p class="lead">A SimpleWay pode funcionar como curso próprio, programa complementar ou trilha de inglês com app e acompanhamento.</p><div class="actions"><a class="btn btn-primary" href="/contato">Falar sobre parceria</a><a class="btn btn-outline" href="/metodologia">Ver método</a></div></div>
        <aside class="card hero-panel"><strong>B2B</strong><p>Turmas, relatórios, rotina de estudo e proposta premium para parceiros.</p></aside>
      </div>
    </section>
    <section class="section"><div class="container cards-3"><article class="card step-card"><span>Escolas</span><h2>Complemento moderno</h2><p>Uma camada digital com prática, speaking e progressão para enriquecer o ensino.</p></article><article class="card step-card"><span>Empresas</span><h2>Inglês aplicado</h2><p>Trilhas de comunicação para equipes, atendimento e desenvolvimento profissional.</p></article><article class="card step-card"><span>Parceiros</span><h2>Produto escalável</h2><p>Marca, site, app e metodologia com estrutura para crescer de forma organizada.</p></article></div></section>
  </main><Footer />
</BaseLayout>

<style>
  .page-hero { padding-top: clamp(58px, 8vw, 96px); }
  .page-head { max-width: 900px; }
  .page-head .lead { max-width: 820px; }
  .gap-top { margin-top: 28px; }
  .step-card { display: grid; gap: 12px; }
  .step-card span { color: #ffd166; font-weight: 900; text-transform: uppercase; letter-spacing: .12em; font-size: .78rem; }
  .list { display: grid; gap: 12px; padding: 0; margin: 0; list-style: none; }
  .list li { padding: 14px 16px; border-radius: 16px; background: rgba(0,87,216,.12); border: 1px solid rgba(234,234,234,.1); color: #d8e0eb; font-weight: 800; }
  .hero-panel { min-height: 360px; display: grid; align-content: center; }
  .hero-panel strong { color: #ffd166; font-size: 3rem; font-family: Poppins, Inter, sans-serif; line-height: 1; }
  .cta-band { background: linear-gradient(90deg, rgba(0,87,216,.22), rgba(255,209,102,.09)); border-block: 1px solid rgba(234,234,234,.08); }
  .actions { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 28px; }
  @media(max-width:720px){ .actions{display:grid}.hero-panel{min-height:auto}.hero-panel strong{font-size:2.3rem} }
</style>
