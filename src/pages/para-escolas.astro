---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LeadForm from '../components/LeadForm.astro';
import Icon from '../components/Icon.astro';
import { unsplash } from '../data/site';
---
<BaseLayout title="SimpleWay para escolas e empresas | Inglês com método e app" description="Leve a SimpleWay Academy para escolas, empresas e turmas fechadas com metodologia própria, app, progresso, speaking e acompanhamento.">
  <Header />
  <main id="conteudo">
    <section class="section page-hero"><div class="container grid-2"><div><p class="eyebrow">B2B educacional</p><h1>Uma solução de inglês para escolas, empresas e turmas fechadas.</h1><p class="lead">A SimpleWay pode funcionar como braço metodológico e tecnológico para instituições que querem oferecer inglês com experiência moderna, progressiva e mensurável.</p></div><div class="image-frame"><img src={unsplash.classroom} alt="Sala de aula com estudantes" loading="eager" width="1200" height="900" /></div></div></section>
    <section class="section"><div class="container grid-3"><article class="card"><span class="icon-bubble"><Icon name="school" /></span><h3>Turmas fechadas</h3><p>Trilhas por nível, rotina de speaking e acompanhamento do avanço dos alunos.</p></article><article class="card"><span class="icon-bubble red"><Icon name="chart" /></span><h3>Relatórios</h3><p>Progresso por habilidade e visão clara de engajamento, revisão e domínio.</p></article><article class="card"><span class="icon-bubble gold"><Icon name="phone" /></span><h3>App como plataforma</h3><p>O aluno estuda em uma experiência digital com lições, cards e checkpoints.</p></article></div></section>
    <section class="section form-section"><div class="container grid-2"><div><p class="eyebrow">Parceria</p><h2>Vamos desenhar um piloto para sua escola ou empresa?</h2><p class="lead">Use o formulário para abrir uma conversa pelo WhatsApp e explicar o cenário: número de alunos, faixa etária, objetivo e formato desejado.</p></div><LeadForm title="Quero uma parceria SimpleWay" /></div></section>
  </main>
  <Footer />
</BaseLayout>
<style>.page-hero{background:linear-gradient(135deg,#eaf3ff,#fff6d8)}.card h3{margin:16px 0 8px}.card p{color:var(--sw-muted)}.form-section{background:#fff}</style>
