---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Política de Privacidade | SimpleWay Academy">
  <Header />
  <main class="section">
    <div class="narrow">
      <p class="eyebrow">LGPD</p>
      <h1>Política de Privacidade</h1>
      <p>Esta página será refinada juridicamente antes da publicação final. A SimpleWay Academy coleta dados de contato apenas para atendimento, pré-matrícula e relacionamento com interessados.</p>
      <p>Assinatura do produto: Tehkné Solutions.</p>
    </div>
  </main>
  <Footer />
</BaseLayout>
