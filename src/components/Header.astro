---
import { navItems, site } from '../data/site';
---
<header class="site-header">
  <div class="container nav-wrap">
    <a class="brand" href="/" aria-label="SimpleWay Academy Home">
      <span class="brand-mark">SW</span>
      <span>{site.name}</span>
    </a>
    <nav aria-label="Menu principal">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a class="btn btn-primary" href="/pre-matricula">Pré-matrícula</a>
  </div>
</header>
<style>
  .site-header { position: sticky; top: 0; z-index: 50; border-bottom: 1px solid rgba(234,234,234,.08); background: rgba(13,17,23,.78); backdrop-filter: blur(18px); }
  .nav-wrap { min-height: 76px; display: flex; align-items: center; justify-content: space-between; gap: 22px; }
  .brand { display: inline-flex; align-items: center; gap: 12px; color: #fff; text-decoration: none; font-weight: 900; letter-spacing: -0.03em; }
  .brand-mark { display: grid; place-items: center; width: 42px; height: 42px; border-radius: 14px; background: linear-gradient(135deg, #0057d8, #ffd166); color: #0d1117; font-size: .82rem; }
  nav { display: flex; align-items: center; gap: 20px; color: #a8b3c3; font-size: .92rem; font-weight: 800; }
  nav a { text-decoration: none; }
  nav a:hover { color: #ffd166; }
  @media (max-width: 920px) { nav { display: none; } .nav-wrap { min-height: 68px; } }
</style>
