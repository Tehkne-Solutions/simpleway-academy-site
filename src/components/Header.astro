---
import { navItems, site } from '../data/site';
---
<a href="#conteudo" class="skip-link">Pular para o conteúdo</a>
<header class="site-header" data-header>
  <div class="container nav-shell">
    <a class="brand" href="/" aria-label="SimpleWay Academy - início">
      <span class="brand-mark" aria-hidden="true">
        <img src={site.logos.mark} alt="" width="44" height="48" loading="eager" decoding="async" />
      </span>
      <span class="brand-copy"><strong>SimpleWay</strong><small>Academy</small></span>
    </a>

    <button class="menu-button" aria-label="Abrir menu" aria-expanded="false" data-menu-button>
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" data-nav aria-label="Menu principal">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href={site.appUrl} class="nav-app">Acessar app</a>
      <a href="/pre-matricula/" class="btn btn-primary nav-cta">Pré-matrícula</a>
    </nav>
  </div>
</header>
<script is:inline>
  const button = document.querySelector('[data-menu-button]');
  const nav = document.querySelector('[data-nav]');
  if (button && nav) {
    button.addEventListener('click', () => {
      const open = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', String(!open));
      nav.classList.toggle('is-open', !open);
    });
  }
</script>
<style>
  .site-header{position:sticky;top:0;z-index:50;background:rgba(255,253,247,.9);backdrop-filter:blur(18px);border-bottom:1px solid rgba(16,32,51,.08)}
  .nav-shell{height:76px;display:flex;align-items:center;justify-content:space-between;gap:18px}
  .brand{display:inline-flex;align-items:center;gap:11px;text-decoration:none;min-width:max-content}
  .brand-mark{width:48px;height:48px;border-radius:16px;background:linear-gradient(145deg,#ffffff,#f5f8ff);display:grid;place-items:center;box-shadow:0 12px 26px rgba(0,87,216,.14);border:1px solid rgba(0,87,216,.1);overflow:hidden}
  .brand-mark img{width:34px;height:38px;object-fit:contain;filter:drop-shadow(0 4px 5px rgba(16,32,51,.18))}
  .brand-copy strong{display:block;font-family:Poppins,Inter,sans-serif;font-size:1rem;letter-spacing:-.03em;color:var(--sw-ink);line-height:1}
  .brand-copy small{display:block;color:var(--sw-muted);font-weight:900;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;margin-top:3px}
  .site-nav{display:flex;align-items:center;gap:18px;font-weight:900;font-size:.93rem;color:var(--sw-muted)}
  .site-nav a{text-decoration:none}.site-nav>a:not(.btn):hover{color:var(--sw-blue)}
  .nav-app{color:var(--sw-red)!important}.nav-cta{min-height:42px;padding:10px 16px;color:#fff!important}
  .menu-button{display:none;width:46px;height:46px;border:0;background:var(--sw-blue);border-radius:14px;padding:12px;box-shadow:0 12px 24px rgba(0,87,216,.22)}
  .menu-button span{display:block;height:2px;background:white;border-radius:4px;margin:5px 0}
  @media(max-width:980px){
    .menu-button{display:block}.site-nav{position:absolute;left:16px;right:16px;top:84px;display:grid;gap:8px;background:white;border:1px solid var(--sw-line);border-radius:24px;box-shadow:var(--shadow-soft);padding:14px;opacity:0;transform:translateY(-12px);pointer-events:none;transition:.18s ease}.site-nav.is-open{opacity:1;transform:translateY(0);pointer-events:auto}.site-nav a:not(.btn){padding:13px;border-radius:14px}.site-nav a:not(.btn):hover{background:#f4f7ff}.nav-cta{width:100%}
  }
  @media(max-width:390px){.brand-copy strong{font-size:.92rem}.brand-copy small{font-size:.66rem}.brand-mark{width:44px;height:44px}.brand-mark img{width:31px;height:35px}.nav-shell{height:70px}}
</style>
