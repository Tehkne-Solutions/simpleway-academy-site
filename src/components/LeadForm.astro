---
import { site } from '../data/site';
const { compact = false, title = 'Quero conhecer a SimpleWay' } = Astro.props;
---
<form class={`lead-form ${compact ? 'is-compact' : ''}`} data-lead-form>
  <div class="form-head">
    <span>🚀</span>
    <div>
      <h3>{title}</h3>
      <p>Preencha e abra uma mensagem pronta no WhatsApp da SimpleWay.</p>
    </div>
  </div>
  <div class="form-grid">
    <label>Nome
      <input name="nome" required placeholder="Seu nome" />
    </label>
    <label>WhatsApp
      <input name="telefone" inputmode="tel" placeholder="(19) 99999-9999" />
    </label>
    <label>E-mail
      <input name="email" type="email" placeholder="voce@email.com" />
    </label>
    <label>Objetivo
      <select name="objetivo">
        <option>Destravar a fala</option>
        <option>Inglês para trabalho</option>
        <option>Inglês para escola/faculdade</option>
        <option>Turma para escola/empresa</option>
        <option>Quero testar o app</option>
      </select>
    </label>
  </div>
  <label>Mensagem
    <textarea name="mensagem" placeholder="Conte seu nível atual, horário preferido ou dúvida principal"></textarea>
  </label>
  <button class="btn btn-primary" type="submit">Enviar pelo WhatsApp</button>
  <p class="privacy">Ao enviar, você será redirecionado para o WhatsApp {site.whatsappDisplay}. Nenhum dado é salvo neste formulário estático.</p>
</form>
<script define:vars={{ phone: site.whatsappNumber }}>
  const forms = document.querySelectorAll('[data-lead-form]');
  forms.forEach((form) => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const message = [
        'Olá! Quero saber mais sobre a SimpleWay Academy.',
        `Nome: ${data.get('nome') || ''}`,
        `WhatsApp: ${data.get('telefone') || ''}`,
        `E-mail: ${data.get('email') || ''}`,
        `Objetivo: ${data.get('objetivo') || ''}`,
        `Mensagem: ${data.get('mensagem') || ''}`
      ].join('\n');
      window.open(`https://wa.me/${phone}?text=${encodeURIComponent(message)}`, '_blank', 'noopener,noreferrer');
    });
  });
</script>
<style>
  .lead-form{background:white;border:1px solid var(--sw-line);border-radius:30px;box-shadow:var(--shadow-color);padding:clamp(20px,3vw,30px)}
  .form-head{display:flex;gap:14px;align-items:flex-start;margin-bottom:20px}.form-head span{width:54px;height:54px;border-radius:18px;background:var(--sw-gold);display:grid;place-items:center;font-size:1.5rem;flex:0 0 auto}.form-head h3{margin:0 0 6px}.form-head p{margin:0;color:var(--sw-muted)}
  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}.lead-form label{display:grid;gap:7px;font-weight:900;color:var(--sw-ink);margin-bottom:14px}.lead-form input,.lead-form select,.lead-form textarea{border:1px solid rgba(16,32,51,.14);border-radius:16px;padding:13px 14px;background:#fbfdff;color:var(--sw-ink);width:100%;outline:none}.lead-form textarea{min-height:106px;resize:vertical}.lead-form input:focus,.lead-form select:focus,.lead-form textarea:focus{border-color:var(--sw-blue);box-shadow:0 0 0 4px rgba(0,87,216,.1)}.privacy{font-size:.85rem;color:var(--sw-muted);margin:14px 0 0}.is-compact .form-grid{grid-template-columns:1fr}.is-compact textarea{min-height:88px}
  @media(max-width:720px){.form-grid{grid-template-columns:1fr}.form-head{display:block}.form-head span{margin-bottom:12px}}
</style>
