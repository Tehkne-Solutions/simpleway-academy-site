---
import { navItems, site } from '../data/site';
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-about">
      <a class="footer-brand" href="/" aria-label="SimpleWay Academy - início">
        <img src={site.logos.full} alt="SimpleWay Academy — Aprenda com leveza, evolua com propósito" width="300" height="323" loading="lazy" decoding="async" />
      </a>
      <p>{site.tagline}</p>
      <p class="signature">Produto desenvolvido por <strong>Tehkné Solutions</strong>.</p>
    </div>
    <div>
      <h3>Institucional</h3>
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </div>
    <div>
      <h3>Contato</h3>
      <a href={`https://wa.me/${site.whatsappNumber}`}>WhatsApp {site.whatsappDisplay}</a>
      <a href="/contato/">Página de contato</a>
      <a href={site.appUrl}>Acessar app</a>
    </div>
    <div>
      <h3>Legal</h3>
      <a href="/politica-de-privacidade/">Política de privacidade</a>
      <a href="/termos-de-uso/">Termos de uso</a>
      <a href="/faq/">FAQ</a>
    </div>
  </div>
  <div class="container footer-bottom">© {year} SimpleWay Academy. Todos os direitos reservados.</div>
</footer>
<style>
  .footer{padding:60px 0 24px;background:linear-gradient(135deg,#102033,#143a72);color:white;position:relative;overflow:hidden}
  .footer::before{content:"";position:absolute;inset:auto -120px -180px auto;width:360px;height:360px;border-radius:999px;background:rgba(255,209,102,.28)}
  .footer::after{content:"";position:absolute;inset:-140px auto auto -120px;width:280px;height:280px;border-radius:999px;background:rgba(230,57,70,.14)}
  .footer-grid{display:grid;grid-template-columns:1.45fr repeat(3,1fr);gap:28px;position:relative;z-index:1}
  .footer a{display:block;color:rgba(255,255,255,.76);text-decoration:none;font-weight:800;margin:10px 0}.footer a:hover{color:var(--sw-gold)}
  .footer h3{font-size:1rem;color:white;margin-bottom:12px}.footer p{color:rgba(255,255,255,.72);max-width:36ch}.signature strong{color:var(--sw-gold)}
  .footer-brand{display:inline-flex!important;margin:0 0 14px!important;max-width:min(300px,100%);border-radius:26px;padding:14px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);box-shadow:0 24px 54px rgba(0,0,0,.16)}
  .footer-brand img{width:100%;height:auto;max-height:250px;object-fit:contain;filter:drop-shadow(0 12px 18px rgba(0,0,0,.28))}
  .footer-bottom{position:relative;z-index:1;margin-top:34px;padding-top:18px;border-top:1px solid rgba(255,255,255,.14);color:rgba(255,255,255,.7);font-size:.9rem}
  @media(max-width:900px){.footer-grid{grid-template-columns:1fr 1fr}.footer-about{grid-column:1/-1}.footer-brand{max-width:250px}}
  @media(max-width:560px){.footer-grid{grid-template-columns:1fr}.footer{padding-bottom:calc(24px + env(safe-area-inset-bottom))}.footer-brand{max-width:220px}.footer-brand img{max-height:210px}}
</style>
