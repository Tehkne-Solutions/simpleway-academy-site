+export function articleSchema(post: { title: string; description: string; slug: string }) {
+  return {
+    '@context': 'https://schema.org',
+    '@type': 'Article',
+    headline: post.title,
+    description: post.description,
+    url: `${site.url}/blog/${post.slug}`,
+    author: {
+      '@type': 'Organization',
+      name: site.name
+    },
+    publisher: {
+      '@type': 'Organization',
+      name: site.name
+    },
+    inLanguage: 'pt-BR'
+  };
+}
